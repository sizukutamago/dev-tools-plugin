{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/schemas/hooks.json",
  "description": "Combined hooks for dev-tools-plugin",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/hurikaeri/scripts/suggest_hurikaeri.sh\"",
            "timeout": 5000,
            "onError": "ignore"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/prompt-improver/scripts/stop_hook_collect.sh\"",
            "timeout": 5000,
            "onError": "ignore"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/obsidian-context/scripts/session-start.sh\"",
            "timeout": 3000,
            "onError": "ignore"
          }
        ]
      }
    ]
  }
}
